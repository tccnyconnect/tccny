---
export interface Props {
  title: string;
  description: string;
  image?: {
    url: string;
    alt: string;
  };
  type?: "website" | "article";
  canonicalUrl?: string;
}

const {
  title,
  description,
  image = {
    url: "/uploads/tccny-logo.png",
    alt: "Telugu Christian Church New York (TCCNY)",
  },
  type = "website",
  canonicalUrl,
} = Astro.props;

// Ensure your domain is correct
const siteUrl = "https://tccny.church";
const canonicalURL = canonicalUrl || new URL(Astro.url.pathname, siteUrl);
const socialImageURL = new URL(image.url, siteUrl);

// Church Information Configuration
const churchInfo = {
  name: "Telugu Christian Church, New York (TCCNY)",
  legalName: "Telugu Christian Church of New York",
  address: {
    streetAddress: "262-22 Union Tpke",
    addressLocality: "Floral Park",
    addressRegion: "NY",
    postalCode: "11004",
    addressCountry: "US",
  },
  telephone: "+1-213-822-4884",
  email: "tccnyconnect@gmail.com",
  url: siteUrl,
  logo: `${siteUrl}/uploads/TCCNY-logo.png`,
};

// JSON-LD Structured Data for Google (Church & Organization)
const schemaData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Church",
      "@id": `${siteUrl}/#organization`,
      "name": churchInfo.name,
      "legalName": churchInfo.legalName,
      "url": churchInfo.url,
      "logo": {
        "@type": "ImageObject",
        "url": churchInfo.logo,
        "width": "512",
        "height": "512"
      },
      "address": {
        "@type": "PostalAddress",
        "streetAddress": churchInfo.address.streetAddress,
        "addressLocality": churchInfo.address.addressLocality,
        "addressRegion": churchInfo.address.addressRegion,
        "postalCode": churchInfo.address.postalCode,
        "addressCountry": churchInfo.address.addressCountry
      },
      "telephone": churchInfo.telephone,
      "email": churchInfo.email,
      "description": description,
      "sameAs": [
        "https://facebook.com/tccny",
        "https://instagram.com/tccny",
        "https://youtube.com/@tccny"
      ],
      "openingHoursSpecification": [
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": "Sunday",
          "opens": "16:00",
          "closes": "18:00"
        }
      ]
    },
    {
      "@type": "WebSite",
      "@id": `${siteUrl}/#website`,
      "url": churchInfo.url,
      "name": churchInfo.name,
      "publisher": { "@id": `${siteUrl}/#organization` }
    }
  ]
};
---

<title>{title} | TCCNY</title>
<meta name="title" content={`${title} | TCCNY`} />
<meta name="description" content={description} />
<link rel="canonical" href={canonicalURL} />

<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="theme-color" content="#4f46e5" /> <meta property="og:type" content={type} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={socialImageURL} />
<meta property="og:image:alt" content={image.alt} />
<meta property="og:site_name" content="TCCNY" />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={canonicalURL} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={socialImageURL} />
<meta name="twitter:image:alt" content={image.alt} />

<meta name="robots" content="index, follow" />

<script type="application/ld+json" set:html={JSON.stringify(schemaData)} />