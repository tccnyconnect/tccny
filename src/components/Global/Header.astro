---
import Navigation from "./Navigation.astro";
import { Image } from 'astro:assets';
import myLogo from '../';
---

<header class="sticky top-0 z-50 w-full bg-white/90 backdrop-blur-md shadow-sm p-2">
  <div class="container flex items-center justify-between h-20">


<a href="/" class="text-2xl px-2 font-bold text-primary-800 font-serif flex items-center">
      <span class="sr-only">Telugu Christian Community New York</span>
      <Image 
        src='/public/uploads/TCCNY-logo.png' 
        alt="TCCNY Logo" 
        width="80"
        height="30" 
      />
      
      <div class="flex flex-col ml-3">
        <span class="text-primary-800 leading-tight">Telugu Christian Church</span>
        <span class="text-primary-800 text-lg leading-tight">New York</span>
      </div>
    </a>
    
    <Navigation />
  </div>
</header>