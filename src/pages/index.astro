---
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroSection from "../components/Sections/HeroSection.astro";
import Button from "../components/UI/Button.astro";
---

<BaseLayout
  title="Home - Telugu Christian Church New York"
  description="A Christ-centered Telugu community church in Queens, NYC dedicated to worship, fellowship, and service."
>
  <HeroSection 
    title="Welcome to Our Church"
    subtitle="A Christ-centered Telugu community in New York dedicated to worship, fellowship, and service."
    backgroundImage="/uploads/hero-bg.webp"
    ctaText="Plan Your Visit"
    ctaLink="/contact"
    secondaryCtaText="Learn More"
    secondaryCtaLink="/about-us"
  />
  
  <section class="py-16 md:py-24 bg-white border-b border-gray-100">
    <div class="container mx-auto px-4">
      <div class="max-w-6xl mx-auto text-center">
        <h2 class="text-2xl md:text-5xl font-extrabold tracking-tight text-gray-900 mb-10">
          Join Us This Week
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8 mb-12 text-center">
          
          <div class="bg-primary-50 border border-primary-100 p-8 rounded-2xl shadow-sm transition-transform duration-300 hover:-translate-y-1 relative overflow-hidden">
            <div class="inline-flex items-center justify-center px-3 py-1 mb-4 text-xs font-bold tracking-wide text-primary-700 uppercase bg-primary-100 rounded-full">
              Special Event
            </div>
            <h3 class="text-2xl font-bold mb-2 text-gray-900">Easter Sunrise Service</h3>
            <p class="text-2xl font-extrabold text-primary-600 mb-3">6:00 AM</p>
            <p class="text-lg text-gray-700 mb-6">Sunday, April 5th</p>
            
            <div class="flex items-center justify-center text-sm font-medium text-gray-500">
              <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.243-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              In-person
            </div>
          </div>
          
          <div class="bg-gray-50 border border-gray-100 p-8 rounded-2xl shadow-sm transition-transform duration-300 hover:-translate-y-1">
            <div class="inline-flex items-center justify-center px-3 py-1 mb-4 text-xs font-bold tracking-wide text-gray-600 uppercase bg-gray-200 rounded-full">
              Every Sunday
            </div>
            <h3 class="text-2xl font-bold mb-2 text-gray-900">Worship Service</h3>
            <p class="text-2xl font-extrabold text-primary-600 mb-3">4:00 PM</p>
            <p class="text-lg text-gray-700 mb-6">Telugu Service</p>
            
            <div class="flex items-center justify-center text-sm font-medium text-gray-500">
              <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.243-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              In-person
            </div>
          </div>

          <div class="bg-gray-50 border border-gray-100 p-8 rounded-2xl shadow-sm transition-transform duration-300 hover:-translate-y-1">
            <div class="inline-flex items-center justify-center px-3 py-1 mb-4 text-xs font-bold tracking-wide text-gray-600 uppercase bg-gray-200 rounded-full">
              Mon — Thu
            </div>
            <h3 class="text-2xl font-bold mb-2 text-gray-900">Family Prayer</h3>
            <p class="text-2xl font-extrabold text-primary-600 mb-3">8:30 PM</p>
            <p class="text-lg text-gray-700 mb-6">Daily Online Gathering</p>
            
            <div class="flex items-center justify-center text-sm font-medium text-gray-500">
              <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
              Zoom Meeting
            </div>
          </div>

          <div class="bg-gray-50 border border-gray-100 p-8 rounded-2xl shadow-sm transition-transform duration-300 hover:-translate-y-1">
            <div class="inline-flex items-center justify-center px-3 py-1 mb-4 text-xs font-bold tracking-wide text-gray-600 uppercase bg-gray-200 rounded-full">
              Every Friday
            </div>
            <h3 class="text-2xl font-bold mb-2 text-gray-900">Bible Study</h3>
            <p class="text-2xl font-extrabold text-primary-600 mb-3">8:30 PM</p>
            <p class="text-lg text-gray-700 mb-6">Deep Dive into Word</p>
            
            <div class="flex items-center justify-center text-sm font-medium text-gray-500">
              <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
              Zoom Meeting
            </div>
          </div>
        </div>

        <div class="flex justify-center">
          <Button href="/contact" variant="outline" size="lg">
            Plan Your Visit
          </Button>
        </div>
      </div>
    </div>
  </section>
  
  <section class="py-16 md:py-24 bg-gray-50">
    <div class="container mx-auto px-4 max-w-6xl">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="flex justify-center lg:justify-end order-2 lg:order-1">
          <div class="relative group">
            <div class="absolute -inset-1 bg-gradient-to-r from-primary-600 to-primary-400 rounded-full blur opacity-25 group-hover:opacity-50 transition duration-1000 group-hover:duration-200"></div>
            <img 
              src="/uploads/TCCNY-logo.png" 
              alt="TCCNY Logo" 
              class="relative object-contain w-64 md:w-80 rounded-full bg-white p-4 shadow-lg"
            />
          </div>
        </div>
        
        <div class="text-center lg:text-left order-1 lg:order-2">
          <h2 class="text-2xl md:text-4xl font-bold text-gray-900 mb-6">About Our Church</h2>
          <div class="space-y-4 text-lg text-gray-700 leading-relaxed">
            <p>
              Welcome to TCCNY. We are a warm and loving Christ-centered Telugu community in Queens, dedicated to spiritual growth and heartfelt fellowship. For over 30 years, we have been a spiritual home for families to grow in their relationship with God.
            </p>
            <p>
              Whether you are new to New York or looking for a church family that cherishes Telugu culture and biblical truth, we invite you to be our guest this Sunday.
            </p>
          </div>
          <div class="mt-8 flex justify-center lg:justify-start">
            <Button href="/about-us" variant="outline">
              Learn More About Us
            </Button>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section 
    class="py-20 bg-cover bg-fixed bg-center relative overflow-hidden"
    style="background-image: url(/uploads/comunity-bg.webp)"
  >
    <div class="absolute inset-0 bg-black/60 backdrop-blur-[2px]"></div>
    <div class="container relative z-10 mx-auto px-4 text-center">
      <div class="max-w-2xl mx-auto">
        <h2 class="text-2xl md:text-5xl font-bold mb-6 text-white tracking-tight">Ready to Join Our Community?</h2>
        <p class="text-2xl mb-10 text-gray-200">
          We'd love to welcome you to our church family. Come visit us this Sunday or reach out with any questions.
        </p>
        <div class="flex justify-center">
          <Button href="/contact" variant="outline" size="md" class="bg-white text-gray-900 border-white hover:bg-transparent hover:text-white transition-all duration-300">
            Contact Us Today
          </Button>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>