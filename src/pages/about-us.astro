---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/Sections/PageHeader.astro";
import StaffList from "../components/Sections/StaffList.astro";
---

<BaseLayout
  title="About Us - Telugu Christian Church New York"
  description="Learn about our church's history, mission, values, and the people who make our community special."
>
  <PageHeader 
    title="About Us" 
    subtitle="Our History, Mission, and Values"
    backgroundImage="https://images.unsplash.com/photo-1438032005730-c779502df39b?w=1920&h=600&fit=crop&crop=center"
  />
  
  <section class="py-16 md:py-24 bg-white dark:bg-gray-900">
    <div class="container mx-auto px-4 max-w-4xl">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-5xl font-extrabold tracking-tight text-gray-900 dark:text-white mb-6">Who We Are</h2>
      </div>

      <div class="space-y-6 text-lg md:text-xl text-gray-700 dark:text-gray-300 leading-relaxed">
        <p>
          Welcome to our Telugu Christian Church, New York. Located in the heart of Queens, we are a Christ-centered Telugu community dedicated to worship, fellowship, and service. For over 30 years, we have stood firm in the Christian faith, rooted in the truth of God’s Word and the teachings passed down through generations.
        </p>
        <p>
          We are a family of believers sharing God’s love with people from all walks of life, especially those who cherish the Telugu language and culture while living in the United States.
        </p>

        <div class="py-8 space-y-6">
          <blockquote class="pl-6 border-l-4 border-primary-500 bg-gray-50 dark:bg-gray-800/50 py-4 pr-4 rounded-r-lg">
            <p class="text-xl italic font-serif text-gray-900 dark:text-white">
              "Your word is a lamp for my feet, a light on my path." 
              <span class="block mt-2 text-base font-sans text-gray-500 dark:text-gray-400 font-semibold">— Psalms 119:105</span>
            </p>
          </blockquote>

          <blockquote class="pl-6 border-l-4 border-primary-500 bg-gray-50 dark:bg-gray-800/50 py-4 pr-4 rounded-r-lg">
            <p class="text-xl italic font-serif text-gray-900 dark:text-white">
              "Not giving up meeting together... but encouraging one another—and even more as you see the Day approaching."
              <span class="block mt-2 text-base font-sans text-gray-500 dark:text-gray-400 font-semibold">— Hebrews 10:25</span>
            </p>
          </blockquote>

          <blockquote class="pl-6 border-l-4 border-primary-500 bg-gray-50 dark:bg-gray-800/50 py-4 pr-4 rounded-r-lg">
            <div class="space-y-4">
              <p class="text-xl italic font-serif text-gray-900 dark:text-white">
                "Love one another as I have loved you." 
                <span class="block mt-1 text-base font-sans text-gray-500 dark:text-gray-400 font-semibold">— John 13:34</span>
              </p>
                </blockquote>

                <blockquote class="pl-6 border-l-4 border-primary-500 bg-gray-50 dark:bg-gray-800/50 py-4 pr-4 rounded-r-lg">
              <p class="text-xl italic font-serif text-gray-900 dark:text-white">
                "Go into all the world and preach the gospel to all creation." 
                <span class="block mt-1 text-base font-sans text-gray-500 dark:text-gray-400 font-semibold">— Mark 16:15</span>
              </p>
            </div>
          </blockquote>
        </div>

        <p>
          Our church is a spiritual home where faith and tradition come together. We conduct worship services in Telugu, creating a meaningful experience for individuals and families to grow in their relationship with God. Through prayer, biblical teaching, and heartfelt worship, we aim to strengthen faith and encourage a deeper understanding of God’s Word.
        </p>
        <p>
          Beyond Sunday services, we offer ministries for children, youth, and adults, along with Bible study, daily prayer meetings, and Gospel outreach programs.
        </p>
        <p>
          Whether you are new to the area, looking for a church family, or exploring faith for the first time, we warmly invite you to join us.
        </p>
        
        <div class="mt-8 p-6 bg-primary-50 dark:bg-primary-900/10 rounded-xl border border-primary-100 dark:border-primary-800/50">
          <p class="font-semibold text-gray-900 dark:text-white !mb-0">
            Have questions? Reach out to us: <a href="mailto:TCCNYconnect@gmail.com" class="text-primary-600 dark:text-primary-400 hover:underline">TCCNYconnect@gmail.com</a>
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-gray-50 dark:bg-gray-800">
    <div class="container mx-auto px-4 max-w-5xl">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="bg-white dark:bg-gray-900 p-8 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-700">
          <h2 class="text-3xl font-bold mb-4 text-gray-900 dark:text-white tracking-tight">Our Mission</h2>
          <p class="text-lg text-gray-700 dark:text-gray-300 leading-relaxed">
            To teach the Word of God, spread the Gospel for God’s glory, encourage and equip believers to grow in their faith, and serve the community with love and humility.
          </p>
        </div>
        
        <div class="bg-white dark:bg-gray-900 p-8 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-700">
          <h2 class="text-3xl font-bold mb-4 text-gray-900 dark:text-white tracking-tight">Our Vision</h2>
          <p class="text-lg text-gray-700 dark:text-gray-300 leading-relaxed">
            To be a welcoming Telugu Christian community that inspires spiritual growth, unity, and service in New York and beyond. We look forward to growing together in faith.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24 bg-white dark:bg-gray-900">
    <div class="container mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-extrabold tracking-tight text-gray-900 dark:text-white mb-4">Our Leadership</h2>
        <p class="text-gray-600 dark:text-gray-400">The hearts behind our community</p>
      </div>
      <StaffList showAll={false} limit={3} />
    </div>
  </section>

</BaseLayout>